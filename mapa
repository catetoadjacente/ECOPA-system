        # Frame container com borda neon suave
        self.current_frame = ctk.CTkFrame(self.main_container, corner_radius=20, fg_color=CG_BG_PANEL, border_color=CG_BORDER, border_width=1)
        self.current_frame.pack(expand=True, fill="both", padx=10, pady=10)
        
        # Cabeçalho do Painel
        header_frame = ctk.CTkFrame(self.current_frame, fg_color="transparent")
        header_frame.pack(fill="x", padx=25, pady=(25, 15))
        
        ctk.CTkLabel(header_frame, text=f"{icone} {titulo}", font=("Orbitron", 24, "bold"), text_color=CG_NEON_GREEN, anchor="w").pack(side="left")
        
        # Linha separadora neon pálida
        separator = ctk.CTkFrame(self.current_frame, height=2, fg_color=CG_CYAN_GREEN)
        separator.pack(fill="x", padx=25, pady=(0, 20))

        return self.current_frame

