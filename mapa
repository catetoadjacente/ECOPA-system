    # --- LÓGICA DE RASTREAMENTO (Atualizada) ---

    def iniciar_rastreamento(self):
        if not self.rastreamento_ativo:
            self.rastreamento_ativo = True
            # Atualiza o HUD para modo ativo
            self.label_status_link.configure(text="🛰️ LINK ATIVO (ORBITAL CORE)", text_color=CG_NEON_GREEN)
            self.btn_start.configure(state="disabled", fg_color=CG_BORDER) # Desabilita botão start
            self._simular_rastreamento()

    def _parar_rastreamento(self):
        self.rastreamento_ativo = False
        if self._after_id:
            self.after_cancel(self._after_id)
            self._after_id = None
        
        # Tenta atualizar o HUD se a tela de acompanhamento ainda existir
        try:
            if hasattr(self, 'label_status_link'):
                self.label_status_link.configure(text="🛰️ SINAL CESSADO", text_color="#ffaaaa")
                self.btn_start.configure(state="normal", fg_color=CG_NEON_GREEN)
        except Exception:
            pass # Tela foi fechada

    def _simular_rastreamento(self):
        if not self.rastreamento_ativo:
            return
        try:
            lat, lon = random.choice(COORDS)
            self.label_coords.configure(text=f"{lat:.4f} , {lon:.4f}")
            
            # Adiciona um pequeno efeito visual "pulse" na borda do HUD ao atualizar
            original_border = self.label_coords.master.master.cget("border_color")
            self.label_coords.master.master.configure(border_color=CG_NEON_GREEN)
            self.after(200, lambda: self.label_coords.master.master.configure(border_color=original_border))

        except Exception as e:
            print(f"Erro na simulação: {e}")
            self.rastreamento_ativo = False
            return
        # Taxa de atualização mais rápida para parecer mais dinâmico (1.5s)
        self._after_id = self.after(1500, self._simular_rastreamento)

    def destroy(self):
        self._parar_rastreamento()
        super().destroy()

