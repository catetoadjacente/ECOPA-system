    def _criar_fundo_degrade(self):
        """Cria um Canvas no fundo da janela para desenhar o degradê."""
        # Canvas que ocupa toda a janela
        self.canvas_bg = Canvas(self, highlightthickness=0)
        self.canvas_bg.place(relx=0, rely=0, relwidth=1, relheight=1)
        
        # Vincula o redimensionamento da janela à atualização do degradê
        self.bind("<Configure>", self._desenhar_degrade)

    def _desenhar_degrade(self, event=None):
        """Desenha o degradê radial futurista no Canvas."""
        self.canvas_bg.delete("all") # Limpa desenho anterior
        width = self.winfo_width()
        height = self.winfo_height()

        # Define as cores do degradê (Do centro escuro para as bordas com brilho esmeralda)
        color_center = CG_BG_DARK
        color_edge = "#042618" # Um tom ligeiramente mais claro nas bordas

        # Simula degradê radial desenhando círculos concêntricos
        steps = 50
        for i in range(steps):
            # Calcula o raio e a opacidade baseada no passo
            ratio = i / steps
            
            # Interpolação simples de cor (do escuro para o levemente mais claro)
            # Para degradês complexos, bibliotecas como PIL seriam necessárias, 
            # mas isso resolve nativamente de forma aceitável.
            r1, g1, b1 = self.winfo_rgb(color_center)
            r2, g2, b2 = self.winfo_rgb(color_edge)
            
            nr = int(r1 + (r2 - r1) * ratio)
            ng = int(g1 + (g2 - g1) * ratio)
            nb = int(b1 + (b2 - b1) * ratio)
            color = f'#{nr>>8:02x}{ng>>8:02x}{nb>>8:02x}'

            radius_x = (width * 1.5) * (1 - ratio * 0.8) # Círculos que expandem além da tela
            radius_y = (height * 1.5) * (1 - ratio * 0.8)

            # Desenha a oval centralizada
            x0 = (width / 2) - (radius_x / 2)
            y0 = (height / 2) - (radius_y / 2)
            x1 = (width / 2) + (radius_x / 2)
            y1 = (height / 2) + (radius_y / 2)
            
            self.canvas_bg.create_oval(x0, y0, x1, y1, fill=color, outline=color)

