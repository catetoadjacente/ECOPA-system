        # --- 2. CRIAÇÃO DO FUNDO EM DEGRADÊ ---
        self._criar_fundo_degrade()

        # --- 3. LAYOUT PRINCIPAL (Containers Transparentes) ---
        self.grid_columnconfigure(1, weight=1)
        self.grid_rowconfigure(0, weight=1)

        # Barra Lateral de Menu (Esquerda)
        self.sidebar_frame = ctk.CTkFrame(self, width=240, corner_radius=20, fg_color=CG_BG_PANEL, border_color=CG_BORDER, border_width=1)
        self.sidebar_frame.grid(row=0, column=0, rowspan=4, padx=(20, 10), pady=20, sticky="nsew")
        self.sidebar_frame.grid_rowconfigure(5, weight=1) # Espaçador inferior

